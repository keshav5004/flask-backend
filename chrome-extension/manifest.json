{
  "manifest_version": 3,
  "name": "WebShield - Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time phishing and malicious website detection. Automatically checks every website you visit against a comprehensive threat database.",
  "permissions": [
    "tabs",
    "activeTab",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://flask-backend-52nr.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WebShield - Check Website Safety"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
